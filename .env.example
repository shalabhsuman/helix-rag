# Copy this file to .env and fill in your values.
# Never commit .env to GitHub.

# OpenAI — used for embeddings (text-embedding-3-small) and generation (GPT-4o)
OPENAI_API_KEY=sk-...

# Qdrant — leave blank if running locally via Docker (default)
# Fill in only if using Qdrant Cloud
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# Collection name in Qdrant — change if you want multiple indexes
QDRANT_COLLECTION=helix_rag

# Embedding model — swap to text-embedding-3-large for higher quality at higher cost
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# Generation model
GENERATION_MODEL=gpt-4o

# Chunking settings
CHUNK_SIZE=300
CHUNK_OVERLAP=50
PARENT_CHUNK_SIZE=1200
